#!/bin/bash

umask 077
OUTPUT="$(dirname "$0")/interpreter-audit.txt"

CANDIDATES=(
    /bin/sh
    /bin/bash
    /bin/dash
    /bin/zsh
    /bin/ksh
    /usr/bin/python
    /usr/bin/python3
    /usr/bin/perl
    /usr/bin/ruby
    /usr/bin/node
    /usr/bin/php
    /usr/bin/env
    /usr/bin/lua
    /opt/remi/php84/root/usr/bin/php
)

{
    echo "Identity:"
    id
    echo

    echo "Available interpreters:"
    echo

    for interpreter in "${CANDIDATES[@]}"; do
        if [ ! -e "$interpreter" ]; then
            continue
        fi

        resolved="$(readlink -f "$interpreter")"

        echo "------------------------------"
        echo "Requested path: $interpreter"
        echo "Resolved path:  $resolved"

        stat -Lc \
            'Permissions: %A
Numeric mode: %a
Owner: %U
Group: %G
File type: %F' \
            "$resolved"

        if [ -u "$resolved" ]; then
            echo "WARNING: setuid bit is present"
        else
            echo "Setuid: no"
        fi

        if [ -g "$resolved" ]; then
            echo "Setgid: yes"
        else
            echo "Setgid: no"
        fi

        if command -v getcap >/dev/null 2>&1; then
            capabilities="$(getcap "$resolved" 2>/dev/null)"

            if [ -n "$capabilities" ]; then
                echo "Capabilities: $capabilities"
            else
                echo "Capabilities: none"
            fi
        fi

        echo
    done
} > "$OUTPUT" 2>&1
