#!/bin/bash

umask 077
OUTPUT="$(dirname "$0")/security-test.txt"

{
    echo "Identity:"
    id
    echo

    echo "Sudo permissions:"
    sudo -n -l 2>&1
    echo

    echo "Process security:"
    grep -E '^(Uid|Gid|Groups|CapInh|CapPrm|CapEff|CapBnd|NoNewPrivs):' /proc/self/status
    echo

    echo "Open file descriptors:"
    ls -la /proc/$$/fd
    echo

    echo "Wrapper directory:"
    ls -ld /var/www/html/swrapper
    echo

    if [ -w /var/www/html/swrapper ]; then
        echo "WARNING: wrapper directory is writable"
    else
        echo "Wrapper directory is not writable"
    fi
    echo

    echo "Protected write tests:"

    touch /root/spanel-deploy-test 2>&1 &&
        echo "CRITICAL: could write to /root" ||
        echo "Cannot write to /root"

    touch /etc/spanel-deploy-test 2>&1 &&
        echo "CRITICAL: could write to /etc" ||
        echo "Cannot write to /etc"

    touch /var/www/html/swrapper/spanel-deploy-test 2>&1 &&
        echo "WARNING: could write to wrapper directory" ||
        echo "Cannot write to wrapper directory"
} > "$OUTPUT" 2>&1
